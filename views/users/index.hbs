<section class="container">
  <div class="section-header">
    <div>
      <h2>{{titulo}}</h2>
      <p>Listado de usuarios registrados en la base de datos.</p>
    </div>

    <a href="/usuarios/create" class="btn">Nuevo usuario</a>
  </div>

  <div class="card">
    {{#if users.length}}
      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nombre</th>
              <th>Email</th>
              <th>Edad</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each users}}
              <tr>
                <td>{{this.id}}</td>
                <td>{{this.nombre}}</td>
                <td>{{this.email}}</td>
                <td>{{this.edad}}</td>
                <td>
                  <div class="actions-inline">
                    <a
                      href="/usuarios/edit/{{this.id}}"
                      class="btn btn-small"
                    >Editar</a>

                    <form
                      action="/usuarios/{{this.id}}?_method=DELETE"
                      method="POST"
                      class="inline-form"
                    >
                      <button
                        type="submit"
                        class="btn btn-danger btn-small"
                        onclick="return confirm('¿Deseas eliminar este usuario?')"
                      >
                        Eliminar
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <div class="empty-state">
        <p>No hay usuarios registrados todavía.</p>
        <a href="/usuarios/create" class="btn">Crear el primero</a>
      </div>
    {{/if}}
  </div>
</section>