<section class="container">
  <div class="form-container">
    {{#if error}}
      <div
        class="card"
        style="border: 1px solid rgba(220, 38, 38, 0.25); background: rgba(254, 242, 242, 0.9);"
      >
        <p style="color: #b91c1c; margin-bottom: 0;">{{error}}</p>
      </div>
    {{/if}}

    <div class="card">
      <h2>{{titulo}}</h2>
      <p>Actualiza la información del usuario seleccionado.</p>

      <form
        action="/usuarios/{{user.id}}?_method=PUT"
        method="POST"
        class="form-grid"
      >
        <div class="form-group">
          <label for="nombre">Nombre</label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            value="{{user.nombre}}"
            required
          />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            value="{{user.email}}"
            required
          />
        </div>

        <div class="form-group">
          <label for="edad">Edad</label>
          <input
            type="number"
            id="edad"
            name="edad"
            min="0"
            value="{{user.edad}}"
            required
          />
        </div>

        <div class="actions">
          <button type="submit" class="btn">Actualizar usuario</button>
          <a href="/usuarios/vista" class="btn btn-secondary">Volver</a>
        </div>
      </form>
    </div>
  </div>
</section>